# Supabase 대시보드 → Project Settings → Database → Connection string
# "Session pooler" / "Transaction pooler" URI를 복사하는 것이 가장 정확합니다.
#
# DIRECT_URL: prisma migrate / db pull / introspect (세션 풀러 또는 직접 연결)
# DATABASE_URL: 앱 런타임 (트랜잭션 풀러 6543 + pgbouncer 권장)
#
# 풀러 사용자명은 보통 postgres 가 아니라 postgres.<project-ref> 입니다.
# 비밀번호에 특수문자가 있으면 URL 인코딩(! → %21 등)하세요.

DIRECT_URL="postgresql://postgres.<project-ref>:YOUR_PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres.<project-ref>:YOUR_PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

SESSION_SECRET="change-this-to-a-long-random-string"
